    values:categoryStatus values:AutoAssigned ;
    values:source <https://ihl-databases.icrc.org/en/ihl-treaties/gciv-1949> ;
    rdfs:comment "Re-sourced from authoritative ICRC text; deontic + amendment layers pending." .

